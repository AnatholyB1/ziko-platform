{
  "name": "ziko-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*",
    "backend/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "mobile": "turbo run dev --filter=mobile",
    "backend": "turbo run dev --filter=api",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "react": "^19.1.0",
    "react-native-worklets": "^0.5.1",
    "zod": "^4.3.6"
  }
}
