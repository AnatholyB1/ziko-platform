{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./app/*"]
    },
    "noEmit": true,
    "strict": true,
    "allowImportingTsExtensions": true,
    "types": ["nativewind/types"]
  },
  "include": ["app", "src", "*.ts", "*.tsx", "nativewind-env.d.ts"]
}
