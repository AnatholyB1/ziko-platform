{
  "expo": {
    "name": "Ziko",
    "slug": "ziko-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/image/icon.png",
    "scheme": "ziko",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F7F6F3",
    "splash": {
      "image": "./assets/image/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F6F3"
    },
    "ios": {
      "bundleIdentifier": "com.ziko.mobile",
      "supportsTablet": false,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Ziko reads your health data (steps, heart rate, sleep, workouts) to sync with your fitness profile.",
        "NSHealthUpdateUsageDescription": "Ziko writes workout data back to Apple Health.",
        "NSLocationWhenInUseUsageDescription": "Ziko utilise votre position GPS pour enregistrer vos parcours de course et de vélo.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Ziko utilise votre position GPS pour enregistrer vos parcours en arrière-plan."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true,
        "com.apple.developer.healthkit.access": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/image/adaptive-icon.png",
        "backgroundColor": "#F7F6F3"
      },
      "package": "com.ziko.mobile",
      "minSdkVersion": 26,
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_BODY_FAT",
        "android.permission.health.WRITE_EXERCISE",
        "android.permission.health.WRITE_STEPS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/image/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F6F3",
          "image": "./assets/image/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      [
        "react-native-health-connect",
        {
          "requestPermissions": {
            "read": [
              "Steps", "HeartRate", "SleepSession", "Distance",
              "TotalCaloriesBurned", "ActiveCaloriesBurned",
              "ExerciseSession", "Weight", "BodyFat"
            ],
            "write": ["ExerciseSession", "Steps"]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b672c1a-10c4-4d66-882c-b9a08294650f"
      }
    },
    "owner": "anatholyb"
  }
}
